{
  "name": "nimara-ecommerce",
  "license": "BSD-3-Clause",
  "version": "1.15.0",
  "author": {
    "name": "Mirumee Labs",
    "email": "hello@mirumee.com",
    "url": "https://mirumee.com/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mirumee/nimara-ecommerce"
  },
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "turbo run build",
    "build:marketplace": "turbo run build --filter=marketplace",
    "build:storefront": "turbo run build --filter=storefront",
    "build:stripe": "turbo run build --filter=stripe",
    "build:docs": "turbo run build --filter=docs",
    "start": "turbo run start",
    "start:storefront": "turbo run start --filter=storefront",
    "start:docs": "turbo run start --filter=docs",
    "codegen": "dotenv -e apps/storefront/.env -- turbo run codegen",
    "codegen:saleor": "dotenv -e apps/storefront/.env -- pnpm --filter @nimara/codegen codegen:saleor",
    "codegen:marketplace": "dotenv -e apps/storefront/.env -- pnpm --filter @nimara/codegen codegen:marketplace",
    "codegen:stripe": "dotenv -e apps/storefront/.env -- pnpm --filter @nimara/codegen codegen:stripe",
    "preflight": "tsx apps/storefront/scripts/preflight.mts",
    "dev": "turbo run dev",
    "dev:storefront": "turbo run dev --filter=storefront",
    "dev:marketplace": "turbo run dev --filter=marketplace",
    "dev:stripe": "turbo run dev --filter=stripe",
    "dev:docs": "turbo run dev --filter=docs",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:e2e": "turbo run test:e2e",
    "prepare": "husky",
    "format": "pnpm prettier --write '**/*.{js,ts,tsx,json}'",
    "format:check": "pnpm prettier --check '**/*.{js,ts,tsx,json}'",
    "localstack:up": "docker compose -f apps/marketplace/docker-compose.yml up -d localstack",
    "localstack:down": "docker compose -f apps/marketplace/docker-compose.yml down",
    "localstack:export-secret": "docker compose -f apps/marketplace/docker-compose.yml exec localstack bash /opt/localstack/export-secret.sh",
    "db-ledger:up": "docker compose -f apps/marketplace/docker-compose.yml up -d db-ledger",
    "db-ledger:down": "docker compose -f apps/marketplace/docker-compose.yml stop db-ledger",
    "migrate:ledger": "dotenv -- node apps/marketplace/scripts/migrate-ledger.mjs",
    "fallow": "fallow --format json -c ./packages/config/src/.fallowrc.json > fallow.json",
    "boundary-violations": "fallow dead-code --boundary-violations --format json -c ./packages/config/src/.fallowrc.ca.json > boundary-violations.json",
    "graph": "turbo run build --graph=graph.mermaid"
  },
  "devDependencies": {
    "@nimara/config": "workspace:*",
    "commitizen": "4.3.1",
    "dotenv-cli": "11.0.0",
    "eslint": "^8.57.0",
    "fallow": "2.88.0",
    "husky": "9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.9.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "4.22.4",
    "turbo": "2.9.4"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog",
      "disableScopeLowerCase": true,
      "disableSubjectLowerCase": true,
      "maxHeaderWidth": 150
    }
  }
}
