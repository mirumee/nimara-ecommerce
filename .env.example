# -- REQUIRED ENVIRONMENT VARIABLES --

# Saleor
# A Saleor channel slug that will be used as a default channel on the storefront.
NEXT_PUBLIC_DEFAULT_CHANNEL=
NEXT_PUBLIC_SALEOR_API_URL=
SALEOR_APP_TOKEN=

# URL of the storefront, required for generating the absolute URLs in sitemap.xml, OpenGraph etc.
NEXT_PUBLIC_STOREFRONT_URL=

# Auth.js env - required
AUTH_SECRET="<SOME_RANDOME_STRING>"
# NextAuth env - required only when NOT deploying on Vercel
AUTH_URL=

# Stripe env - required
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
NEXT_PUBLIC_PAYMENT_APP_ID=

# Name of the environment used for sentry: PRODUCTION, STAGING, DEVELOPMENT, LOCAL, TEST
# See: https://docs.sentry.io/concepts/key-terms/environments/
NEXT_PUBLIC_ENVIRONMENT="LOCAL"

# -- OPTIONAL ENVIRONMENT VARIABLES --

# E2E tests - required for Playwright tests in apps/automated-tests, optional for local development of storefront
TEST_ENV_URL=https://localhost:3000
USER_EMAIL="<YOR_EMAIL>"
USER_PASSWORD="<YOUR_PASSWORD>"

# Logging - available levels: debug, info, warn, error, critical; default: debug
LOG_LEVEL=debug

# Sentry - optional, used for error tracking
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG="<YOUR_SENTRY_ORG>"
SENTRY_PROJECT="<YOUR_SENTRY_PROJECT>"
SENTRY_DEBUG=false

# Default image format for Saleor media files.
NEXT_PUBLIC_DEFAULT_IMAGE_FORMAT="AVIF"

# Search engine - available options: "SALEOR", "ALGOLIA"
NEXT_PUBLIC_SEARCH_SERVICE=

# CMS engine - available options: "SALEOR", "BUTTER_CMS"
NEXT_PUBLIC_CMS_SERVICE=

# -- MARKETPLACE APP VARIABLES --

# Storefront: when true, cart only allows products from the same vendor
NEXT_PUBLIC_MARKETPLACE_ENABLED=false

# Server
MARKETPLACE_NODE_ENV=development
MARKETPLACE_PORT=3001
MARKETPLACE_BASE_PATH=

# CORS
MARKETPLACE_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# App config storage provider: "aws" (LocalStack / AWS Secrets Manager) or "edge" (Vercel Edge Config)
MARKETPLACE_APP_CONFIG_PROVIDER=aws

# AWS (LocalStack for development, used when MARKETPLACE_APP_CONFIG_PROVIDER=aws)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SESSION_TOKEN=
AWS_REGION=ap-southeast-1
AWS_ENDPOINT_URL=http://localhost:4566

# Secrets Manager path (used when MARKETPLACE_APP_CONFIG_PROVIDER=aws)
SECRET_MANAGER_APP_CONFIG_PATH=/marketplace/app-config

# Vercel Edge Config (used when MARKETPLACE_APP_CONFIG_PROVIDER=edge)
VERCEL_ACCESS_TOKEN=
VERCEL_TEAM_ID=
VERCEL_EDGE_CONFIG_ID=
MARKETPLACE_APP_CONFIG_EDGE_KEY=marketplace-app-config
# Optional: Edge Config connection string for reads (SDK path).
# When set, reads use @vercel/edge-config SDK instead of REST API.
# Writes always use REST API (VERCEL_ACCESS_TOKEN, etc. still required for setAppConfig/deleteAppConfig).
# MARKETPLACE_EDGE_CONFIG=

# Marketplace URLs
NEXT_PUBLIC_SALEOR_URL=
# On Vercel: automatically uses VERCEL_PROJECT_PRODUCTION_URL (production) or VERCEL_URL (preview)
# Set explicitly only if you need a custom domain
NEXT_PUBLIC_MARKETPLACE_VENDOR_URL=http://localhost:3001
NEXT_PUBLIC_MARKETPLACE_STOREFRONT_URL=http://localhost:3000
NEXT_PUBLIC_SALEOR_MARKETPLACE_CHANNEL_SLUG=default-channel
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3001/api/graphql
NEXT_PUBLIC_SALEOR_UI_APP_TOKEN=

# Marketplace email / SMTP (provider agnostic, e.g. SendGrid SMTP)
MARKETPLACE_SMTP_HOST=
MARKETPLACE_SMTP_PORT=587
MARKETPLACE_SMTP_USER=
MARKETPLACE_SMTP_PASSWORD=
MARKETPLACE_SMTP_SECURE=false
MARKETPLACE_EMAIL_FROM="Nimara Marketplace <no-reply@example.com>"
MARKETPLACE_SUPERADMIN_EMAIL=admin@example.com
