# === REQUIRED (core - storefront, stripe) ===
NEXT_PUBLIC_DEFAULT_CHANNEL=
NEXT_PUBLIC_SALEOR_API_URL=
# SALEOR_APP_TOKEN must include at least MANAGE_PAGES to resolve unpublished vendor profile pages in storefront (/vendor/[slug]).
SALEOR_APP_TOKEN=
NEXT_PUBLIC_STOREFRONT_URL=
AUTH_SECRET=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
NEXT_PUBLIC_PAYMENT_APP_ID=
NEXT_PUBLIC_ENVIRONMENT=LOCAL

# AUTH_URL - required only when NOT deploying on Vercel
# AUTH_URL=

# === REQUIRED (marketplace only) ===
# Marketplace uses NEXT_PUBLIC_SALEOR_API_URL for Saleor GraphQL (same as storefront)
# Set when running marketplace app
NEXT_PUBLIC_SALEOR_URL=

# === DEV / LOCAL (LocalStack, E2E) ===
# AWS - used when MARKETPLACE_APP_CONFIG_PROVIDER=aws (LocalStack for dev)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SESSION_TOKEN=
AWS_REGION=ap-southeast-1
AWS_ENDPOINT_URL=http://localhost:4566

# E2E tests - required for Playwright in apps/automated-tests
TEST_ENV_URL=https://localhost:3000
USER_EMAIL=
USER_PASSWORD=

# === OPTIONAL ===
LOG_LEVEL=debug
NEXT_PUBLIC_DEFAULT_IMAGE_FORMAT=AVIF
NEXT_PUBLIC_SEARCH_SERVICE=
NEXT_PUBLIC_CMS_SERVICE=

# Sentry
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_DEBUG=false

# === MARKETPLACE (optional when not running marketplace) ===
NEXT_PUBLIC_MARKETPLACE_ENABLED=false
MARKETPLACE_NODE_ENV=development
MARKETPLACE_PORT=3001
MARKETPLACE_BASE_PATH=
MARKETPLACE_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
MARKETPLACE_APP_CONFIG_PROVIDER=aws
SECRET_MANAGER_APP_CONFIG_PATH=/marketplace/app-config
VERCEL_ACCESS_TOKEN=
VERCEL_TEAM_ID=
VERCEL_EDGE_CONFIG_ID=
MARKETPLACE_APP_CONFIG_EDGE_KEY=marketplace-app-config
# MARKETPLACE_EDGE_CONFIG=
NEXT_PUBLIC_MARKETPLACE_VENDOR_URL=http://localhost:3001
NEXT_PUBLIC_MARKETPLACE_STOREFRONT_URL=http://localhost:3000
NEXT_PUBLIC_SALEOR_MARKETPLACE_CHANNEL_SLUG=default-channel
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3001/api/graphql
NEXT_PUBLIC_SALEOR_UI_APP_TOKEN=
ALLOWED_SALEOR_DOMAINS=
MARKETPLACE_SMTP_HOST=
MARKETPLACE_SMTP_PORT=587
MARKETPLACE_SMTP_USER=
MARKETPLACE_SMTP_PASSWORD=
MARKETPLACE_SMTP_SECURE=false
MARKETPLACE_EMAIL_FROM=
MARKETPLACE_SUPERADMIN_EMAIL=
