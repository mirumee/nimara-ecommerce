{
  "extends": "@nimara/config/tsconfig/react-library",
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "outDir": "dist",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "exclude": ["node_modules", "dist"]
}
