{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/index.{js,jsx,mjs}", "src/main.{js,jsx,mjs}"],
  "ignorePatterns": [
    "**/generated/**",
    "**/generated/**/*",
    "**/generated.*",
    "packages/codegen/schema.ts",
    "**/*.d.ts",
    "apps/docs/**",
    "**/schema.graphql",
    "**/*.graphql"
  ],
  "workspaces": {
    "packages": ["apps/*", "packages/*"]
  },
  "duplicates": {
    "mode": "semantic",
    "minOccurrences": 3
  },
  "rules": {}
}
