{
  "name": "@nimara/codegen",
  "version": "1.0.0",
  "scripts": {
    "codegen:saleor": "graphql-codegen --config ./codegen.ts --project saleor",
    "codegen:marketplace": "graphql-codegen --config ./codegen.ts --project marketplace",
    "codegen:stripe": "graphql-codegen --config ./codegen.ts --project stripe",
    "codegen": "pnpm codegen:saleor && pnpm codegen:marketplace && pnpm codegen:stripe"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "6.1.2",
    "@graphql-codegen/near-operation-file-preset": "4.0.0",
    "@graphql-codegen/typed-document-node": "6.1.6",
    "@graphql-codegen/typescript": "5.0.8",
    "@graphql-codegen/typescript-operations": "5.0.8",
    "@graphql-typed-document-node/core": "3.2.0",
    "@nimara/config": "workspace:*",
    "@types/node": "^22.19.11",
    "ts-log": "2.2.7",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "graphql": "16.12.0",
    "graphql-config": "5.1.5",
    "ts-invariant": "0.10.3"
  }
}
