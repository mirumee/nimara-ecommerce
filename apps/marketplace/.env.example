# Copy to `.env` and adjust. Many marketplace vars also live in the monorepo root `.env.example`.

# --- Ledger / payout (local Postgres; see docker-compose.yml) ---
# Same DATABASE_URL should exist in the repo root `.env` if you run `pnpm migrate:ledger` from the monorepo root.
# After: `pnpm db-ledger:up` from root (or `docker compose up -d db-ledger` in this directory)
DATABASE_URL=postgresql://marketplace:marketplace@127.0.0.1:5434/marketplace_ledger
