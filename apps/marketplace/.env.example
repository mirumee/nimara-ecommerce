# === REQUIRED — Saleor ===
NEXT_PUBLIC_SALEOR_URL=
NEXT_PUBLIC_SALEOR_API_URL=
NEXT_PUBLIC_SALEOR_UI_APP_TOKEN=
NEXT_PUBLIC_SALEOR_MARKETPLACE_CHANNEL_SLUG=default-channel
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3001/api/graphql
NEXT_PUBLIC_MARKETPLACE_STOREFRONT_URL=http://localhost:3000

# === REQUIRED — App config ===
MARKETPLACE_NODE_ENV=development
MARKETPLACE_PORT=3001
MARKETPLACE_BASE_PATH=
MARKETPLACE_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
MARKETPLACE_APP_CONFIG_PROVIDER=aws
SECRET_MANAGER_APP_CONFIG_PATH=/marketplace/app-config
MARKETPLACE_APP_CONFIG_EDGE_KEY=marketplace-app-config
# MARKETPLACE_EDGE_CONFIG=

ALLOWED_SALEOR_DOMAINS=

# === REQUIRED — Ledger Postgres (drizzle) ===
# After: `pnpm db-ledger:up` from repo root
DATABASE_URL=postgresql://marketplace:marketplace@127.0.0.1:5434/marketplace_ledger

# === REQUIRED — Stripe Connect (vendor onboarding) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
MARKETPLACE_STRIPE_CONNECT_WEBHOOK_SECRET=
MARKETPLACE_STRIPE_CONNECT_DEFAULT_COUNTRY=US

# === REQUIRED — Email (SMTP) ===
MARKETPLACE_SMTP_HOST=localhost
MARKETPLACE_SMTP_PORT=1025
MARKETPLACE_SMTP_SECURE=false
MARKETPLACE_SMTP_USER=
MARKETPLACE_SMTP_PASSWORD=
MARKETPLACE_EMAIL_FROM="Nimara Dev <dev@nimara.local>"
MARKETPLACE_SUPERADMIN_EMAIL=admin@nimara.local

# === LOCAL DEV — AWS (LocalStack when MARKETPLACE_APP_CONFIG_PROVIDER=aws) ===
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SESSION_TOKEN=
AWS_REGION=ap-southeast-1
AWS_ENDPOINT_URL=http://localhost:4566

# === OPTIONAL — Vercel Edge Config (production) ===
VERCEL_ACCESS_TOKEN=
VERCEL_TEAM_ID=
VERCEL_EDGE_CONFIG_ID=
