# =============================================================================
# Nimara Storefront — environment variables
# =============================================================================
# ZERO-CONFIG: every variable below is OPTIONAL. With an empty .env the
# storefront boots and renders every page with empty data (no menu, no
# products, checkout hidden). Set variables only to connect real services.
#
# Copy this file to `.env` and fill in what you need:
#   cp apps/storefront/.env.example apps/storefront/.env
# Run `pnpm preflight` to see which features are currently on/off.
# =============================================================================

# --- Core ---------------------------------------------------------------------
# App environment. One of: TEST | LOCAL | DEVELOPMENT | STAGING | PRODUCTION.
NEXT_PUBLIC_ENVIRONMENT=LOCAL
# Saleor channel slug used for catalog/pricing. Defaults to "default-channel".
NEXT_PUBLIC_DEFAULT_CHANNEL=default-channel
# Contact email shown in the UI. Defaults to contact@mirumee.com.
NEXT_PUBLIC_DEFAULT_EMAIL=
# Public URL of this storefront. Defaults to the Vercel branch URL or localhost:3000.
NEXT_PUBLIC_STOREFRONT_URL=
# Image format served to clients. One of: AVIF | WEBP | ORIGINAL. Defaults to AVIF.
NEXT_PUBLIC_DEFAULT_IMAGE_FORMAT=AVIF

# --- Backend (Saleor) ---------------------------------------------------------
# Saleor GraphQL endpoint. UNSET => zero-config empty mode (no products/menu).
# Example: https://your-store.saleor.cloud/graphql/
NEXT_PUBLIC_SALEOR_API_URL=
# Saleor app token (server-only). Needed for authenticated reads, e.g. loading
# unpublished CMS/vendor pages. Leave empty for anonymous, published content only.
SALEOR_APP_TOKEN=

# --- Auth ---------------------------------------------------------------------
# Secret used by next-auth to sign sessions. Required for customer login.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=
# Only required when NOT deploying on Vercel.
# AUTH_URL=https://my-store.com

# --- Payments (Stripe) --------------------------------------------------------
# Required to enable checkout. All three must be set together.
NEXT_PUBLIC_PAYMENT_APP_ID=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# --- Marketplace --------------------------------------------------------------
# Enable multi-vendor behavior (cart limited to a single vendor). Defaults to false.
NEXT_PUBLIC_MARKETPLACE_ENABLED=false
# Public vendor portal URL (footer link). Empty hides the marketplace column.
NEXT_PUBLIC_MARKETPLACE_VENDOR_URL=

# --- Monitoring (Sentry, optional) --------------------------------------------
# Sentry is only enabled when SENTRY_AUTH_TOKEN, SENTRY_ORG and SENTRY_PROJECT are set.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_DEBUG=false

# --- Analytics (Google Tag Manager, optional) ---------------------------------
# GTM loads only when NEXT_PUBLIC_GTM_ID is set. Google Consent Mode v2 gates
# analytics_storage on the cookie-banner choice; ad signals stay denied.
NEXT_PUBLIC_GTM_ID=
# Optional GTM environment params for preview/staging containers (set together).
NEXT_PUBLIC_GTM_AUTH=
NEXT_PUBLIC_GTM_PREVIEW=
