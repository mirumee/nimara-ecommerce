# === REQUIRED — Saleor / Storefront ===
NEXT_PUBLIC_SALEOR_API_URL=
NEXT_PUBLIC_DEFAULT_CHANNEL=
NEXT_PUBLIC_STOREFRONT_URL=
SALEOR_APP_TOKEN=

# === REQUIRED — Auth ===
AUTH_SECRET=
# AUTH_URL — only when NOT deploying on Vercel
# AUTH_URL=

# === REQUIRED — Payments (Stripe) ===
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
NEXT_PUBLIC_PAYMENT_APP_ID=

# === Environment ===
NEXT_PUBLIC_ENVIRONMENT=LOCAL

# === OPTIONAL — Defaults & UX ===
NEXT_PUBLIC_DEFAULT_IMAGE_FORMAT=AVIF
NEXT_PUBLIC_DEFAULT_PAGE_TITLE=
NEXT_PUBLIC_DEFAULT_EMAIL=

# === OPTIONAL — Search service (Algolia) ===
NEXT_PUBLIC_SEARCH_SERVICE=
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_API_KEY=

# === OPTIONAL — CMS (ButterCMS) ===
NEXT_PUBLIC_CMS_SERVICE=
NEXT_PUBLIC_BUTTER_CMS_API_KEY=

# === OPTIONAL — Marketplace integration ===
NEXT_PUBLIC_MARKETPLACE_ENABLED=false
NEXT_PUBLIC_MARKETPLACE_VENDOR_URL=http://localhost:3001

# === OPTIONAL — Observability ===
LOG_LEVEL=debug
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_DEBUG=false
OTEL_SERVICE_NAME=
