# =============================================================================
# Nimara Stripe App — environment variables
# =============================================================================
# Saleor Payment Gateway app (Next.js, deployed on Vercel).
#
# Copy this file to `.env` and fill in the values:
#   cp apps/stripe/.env.example apps/stripe/.env
#
# NOTE: The per-channel Stripe keys (secret/public) are NOT set here. You enter
# them in the app's dashboard UI after installing it in Saleor; they are stored
# in Vercel Edge Config. That is why this file needs the VERCEL_* variables.
# =============================================================================

# --- Core ---------------------------------------------------------------------
# App environment. One of: TEST | LOCAL | DEVELOPMENT | STAGING | PRODUCTION.
# Also becomes the prefix of the app id in the manifest, e.g. `LOCAL.stripe`.
NEXT_PUBLIC_ENVIRONMENT=LOCAL

# --- Saleor -------------------------------------------------------------------
# Saleor GraphQL endpoint. Must end with a trailing slash `/graphql/`.
# Example: https://your-store.saleor.cloud/graphql/
NEXT_PUBLIC_SALEOR_API_URL=

# --- Vercel Edge Config (app settings storage) --------------------------------
# The app persists its configuration (installed Saleor auth token, per-channel
# Stripe keys) in Vercel Edge Config. All three are required to boot.
# Vercel Dashboard → your project → Storage → create/select an Edge Config.
VERCEL_EDGE_CONFIG_ID=
# Vercel Dashboard → Account Settings → Tokens → Create Token.
VERCEL_ACCESS_TOKEN=
# Vercel Dashboard → Settings → General → Team ID.
VERCEL_TEAM_ID=

# Key under which this app stores its config in Edge Config.
# Optional; defaults to `nimara-config` in code.
CONFIG_KEY=nimara-config

# --- Monitoring (Sentry, optional) --------------------------------------------
# Runtime error reporting is enabled when a DSN is set.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DEBUG=false
# Source-map upload at build time is enabled only when all three are set.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
