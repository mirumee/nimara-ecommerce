{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^codegen", "^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        ".env.production",
        ".env.development",
        "!.env*.local",
        "!.next/**"
      ],
      "env": [
        "NEXT_PUBLIC_SALEOR_API_URL",
        "NEXT_PUBLIC_ENVIRONMENT",
        "CONFIG_KEY",
        "NEXT_PUBLIC_SENTRY_DSN",
        "SENTRY_DSN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_DEBUG"
      ],
      "passThroughEnv": [
        "VERCEL_EDGE_CONFIG_ID",
        "VERCEL_TEAM_ID",
        "VERCEL_ACCESS_TOKEN",
        "SENTRY_AUTH_TOKEN"
      ]
    }
  }
}
