{
  "extends": ["//"],
  "tasks": {
    "test:e2e": {
      "dependsOn": ["test"],
      "env": ["TEST_ENV_URL"],
      "passThroughEnv": ["USER_EMAIL", "USER_PASSWORD"],
      "inputs": [
        "./tests/e2e/**/*.test.ts",
        "./pages/*.ts",
        "./utils/*.ts",
        "playwright.config.json"
      ],
      "outputs": ["playwright-report", "test_results"]
    }
  }
}
