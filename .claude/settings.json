{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm test)",
      "Bash(pnpm format:check)",
      "Bash(pnpm codegen)",
      "Bash(pnpm exec turbo run lint:staged)",
      "Bash(git status)",
      "Bash(git status --short)",
      "Bash(git status --porcelain)",
      "Bash(git status --porcelain=v1)",
      "Bash(git status --porcelain=v2)",
      "Bash(git diff)",
      "Bash(git diff --check)",
      "Bash(git diff --stat)",
      "Bash(git diff --name-only)",
      "Bash(git log)",
      "Bash(git log --oneline)",
      "Bash(git log --oneline --decorate)",
       "Read(./**/.env.example)"
    ],
    "ask": [
      "Bash(pnpm install)",
      "Bash(pnpm install *)",
      "Bash(pnpm i)",
      "Bash(pnpm i *)",
      "Bash(pnpm install-test)",
      "Bash(pnpm install-test *)",
      "Bash(pnpm it)",
      "Bash(pnpm it *)",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)",
      "Bash(pnpm rm *)",
      "Bash(pnpm uninstall *)",
      "Bash(pnpm un *)",
      "Bash(pnpm update)",
      "Bash(pnpm update *)",
      "Bash(pnpm up)",
      "Bash(pnpm up *)",
      "Bash(pnpm upgrade)",
      "Bash(pnpm upgrade *)",
      "Bash(pnpm dlx *)",
      "Bash(pnpm --filter *)",
      "Bash(pnpm --filter=*)",
      "Bash(pnpm -F *)",
      "Bash(pnpm -F=*)",
      "Bash(pnpm -C *)",
      "Bash(pnpm --dir *)",
      "Bash(pnpm -r *)",
      "Bash(pnpm --recursive *)",
      "Bash(pnpm -w *)",
      "Bash(pnpm --workspace-root *)",
      "Bash(pnpm preflight)",
      "Bash(pnpm preflight *)",
      "Bash(git commit)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git -C * commit)",
      "Bash(git -C * commit *)",
      "Bash(git -C * push)",
      "Bash(git -C * push *)",
      "Bash(gh pr create)",
      "Bash(gh pr create *)",
      "Bash(gh --repo * pr create)",
      "Bash(gh --repo * pr create *)",
      "Bash(vercel)",
      "Bash(vercel *)",
      "Bash(terraform apply)",
      "Bash(terraform apply *)",
      "Bash(terraform -chdir=* apply)",
      "Bash(terraform -chdir=* apply *)"
    ],
    "deny": [
      "Read(./**/.env)",
      "Read(./**/.env.local)",
      "Read(./**/.env.*.local)",
      "Read(./**/.env.development)",
      "Read(./**/.env.preview)",
      "Read(./**/.env.production)",
      "Read(./**/.env.staging)",
      "Read(./**/.env.test)",
      "Read(./**/.env.vercel.*)",
      "Read(./**/.env.dzialajace)",
      "Read(./**/*.pem)",
      "Read(./**/private.*.tfvars)",
      "Read(./**/*.tfvars.json)",
      "Edit(./**/.env)",
      "Edit(./**/.env.local)",
      "Edit(./**/.env.*.local)",
      "Edit(./**/.env.development)",
      "Edit(./**/.env.preview)",
      "Edit(./**/.env.production)",
      "Edit(./**/.env.staging)",
      "Edit(./**/.env.test)",
      "Edit(./**/.env.vercel.*)",
      "Edit(./**/.env.dzialajace)",
      "Edit(./**/*.pem)",
      "Edit(./**/private.*.tfvars)",
      "Edit(./**/*.tfvars.json)",
      "Edit(./packages/codegen/schema.ts)",
      "Edit(./**/generated.ts)",
      "Edit(./**/*.generated.ts)",
      "Edit(./**/graphql/generated/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit.sh"
          }
        ]
      }
    ]
  }
}
